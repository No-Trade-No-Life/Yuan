# 本文件只提供变量名示例，不要把真实凭证提交进仓库。

# --- Docker / Host / Postgres ---
HOST_PORT=8888
POSTGRES_PORT=54329
POSTGRES_DB=yuan
POSTGRES_USER=yuants
POSTGRES_PASSWORD=yuants
HOST_TOKEN=replace-me

# --- VEX credential register + OKX upstream ---
VEX_CREDENTIAL_TYPE=OKX
OKX_ACCESS_KEY=
OKX_SECRET_KEY=
OKX_PASSPHRASE=
OKX_USE_HTTP_PROXY=false
# OKX_BROKER_CODE=
# 注意：SQL "order" 表需要由 VEX / 叶子节点 / 外部基础设施维护，signal-trader 默认交付不再捆绑 writer

# --- signal-trader default entry ---
# app-signal-trader 默认假设同一 Host 内服务互信：权限常开、live backend 固定写死在代码里。

# --- optional runtime seed (这些 SIGNAL_TRADER_* 只给 seed-live-runtime.js 用，不影响 app 启动) ---
AUTO_UPSERT_RUNTIME=0
SIGNAL_TRADER_RUNTIME_ID=runtime-live
# 留空时会自动尝试从 QueryPendingOrders 服务发现唯一 trading account_id
# SIGNAL_TRADER_ACCOUNT_ID=
# SIGNAL_TRADER_PRODUCT_ID=SWAP/BTC-USDT-SWAP
SIGNAL_TRADER_SIGNAL_KEY=sig-live
SIGNAL_TRADER_INVESTOR_ID=investor-live
SIGNAL_TRADER_VC_BUDGET=100
SIGNAL_TRADER_DAILY_BURN_AMOUNT=10
SIGNAL_TRADER_SUBSCRIPTION_STATUS=active
SIGNAL_TRADER_POLL_INTERVAL_MS=1000
SIGNAL_TRADER_RECONCILIATION_INTERVAL_MS=10000
SIGNAL_TRADER_EVENT_BATCH_SIZE=100
