    "dev:live:seed": "node ./dev/seed-live-runtime.js"
  },
  "dependencies": {
    "@yuants/data-account": "workspace:*",
    "@yuants/data-order": "workspace:*",
    "@yuants/protocol": "workspace:*",
    "@yuants/signal-trader": "workspace:*",
    "@yuants/sql": "workspace:*",
    "@yuants/utils": "workspace:*"
  },
  "devDependencies": {
    "@microsoft/api-extractor": "~7.55.2",
    "@rushstack/heft": "~1.1.7",
    "@rushstack/heft-jest-plugin": "~1.1.7",
    "@rushstack/heft-node-rig": "~2.11.12",
    "@types/heft-jest": "1.0.6",
    "@types/node": "24",
    "@yuants/tool-kit": "workspace:*",
