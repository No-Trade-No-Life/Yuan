  "homepage": "https://github.com/No-Trade-No-Life/Yuan/tree/main/apps/signal-trader",
  "main": "lib/index.js",
  "module": "dist/index.js",
  "files": [
    "dist",
    "lib",
    "temp"
  ],
  "scripts": {
    "build": "heft test --clean && yuan-toolkit post-build",
    "dev:mock:start": "bash ./dev/run-local-mock-stack.sh start",
    "dev:mock:stop": "bash ./dev/run-local-mock-stack.sh stop",
    "dev:mock:smoke": "bash ./dev/smoke-mock.sh",
    "dev:live:start": "bash ./dev/run-local-live-stack.sh start",
    "dev:live:stop": "bash ./dev/run-local-live-stack.sh stop",
    "dev:live:status": "bash ./dev/run-local-live-stack.sh status",
    "dev:live:dummy:start": "bash ./dev/run-local-live-dummy-stack.sh start",
    "dev:live:dummy:stop": "bash ./dev/run-local-live-dummy-stack.sh stop",
    "dev:live:dummy:status": "bash ./dev/run-local-live-dummy-stack.sh status",
